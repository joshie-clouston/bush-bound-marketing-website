---
export const prerender = true;

import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const services = await getCollection('services', ({ data }) => !data.draft);
  return services.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// Get related pages (same category, excluding self)
const allServices = (await getCollection('services', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);

const relatedModels = entry.data.isCategory
  ? allServices.filter(s => !s.data.isCategory && s.data.parentCategory === entry.id)
  : allServices.filter(s => !s.data.isCategory && s.data.category === entry.data.category && s.id !== entry.id);

const parentCategory = entry.data.isCategory
  ? null
  : allServices.find(s => s.id === entry.data.parentCategory);
---

<BaseLayout title={`${entry.data.title} | Bushbound`} description={entry.data.description}>

  <!-- Breadcrumb -->
  <section class="bg-charcoal pt-6 pb-0">
    <div class="container-narrow">
      <nav class="flex items-center gap-2 text-sm text-stone-dark">
        <a href="/services" class="hover:text-sand transition-colors">Services</a>
        <span>/</span>
        {parentCategory && (
          <>
            <a href={`/services/${parentCategory.id}`} class="hover:text-sand transition-colors">{parentCategory.data.title}</a>
            <span>/</span>
          </>
        )}
        <span class="text-stone-light">{entry.data.title}</span>
      </nav>
    </div>
  </section>

  <!-- Hero -->
  <section class="section-padding bg-charcoal text-stone-light">
    <div class="container-narrow">
      <div class="max-w-3xl">
        {entry.data.categoryLabel && !entry.data.isCategory && (
          <p class="text-sand font-medium text-sm uppercase tracking-widest mb-4">{entry.data.categoryLabel}</p>
        )}
        <h1 class="text-4xl sm:text-5xl font-extrabold mb-6">
          {entry.data.headline || entry.data.title}
        </h1>
        <p class="text-lg text-stone/90 max-w-2xl mb-8">
          {entry.data.description}
        </p>

        <div class="flex flex-wrap gap-6 text-sm">
          {entry.data.priceRange && (
            <div>
              <p class="text-stone-dark uppercase tracking-wider text-xs font-medium mb-1">Price Guide</p>
              <p class="text-sand font-bold text-lg">{entry.data.priceRange}</p>
            </div>
          )}
          {entry.data.turnaround && (
            <div>
              <p class="text-stone-dark uppercase tracking-wider text-xs font-medium mb-1">Turnaround</p>
              <p class="text-stone-light font-semibold text-lg">{entry.data.turnaround}</p>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  {entry.data.features.length > 0 && (
    <section class="section-padding bg-stone">
      <div class="container-narrow">
        <h2 class="text-2xl font-bold text-charcoal mb-8" data-animate="fade-up">What's included</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4" data-animate="stagger">
          {entry.data.features.map((feature) => (
            <div class="flex items-start gap-3 bg-white rounded-lg p-4 border border-stone-dark/10">
              <span class="text-primary font-bold mt-0.5 shrink-0">&#10003;</span>
              <span class="text-sm text-charcoal">{feature}</span>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Content body -->
  <section class="section-padding bg-background">
    <div class="container-narrow">
      <div class="prose prose-lg max-w-3xl
        [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:text-charcoal [&_h2]:mb-4 [&_h2]:mt-0
        [&_h3]:text-xl [&_h3]:font-bold [&_h3]:text-charcoal [&_h3]:mb-3
        [&_p]:text-muted-foreground [&_p]:leading-relaxed [&_p]:mb-4
        [&_ul]:space-y-2 [&_ul]:mb-4
        [&_li]:text-muted-foreground
        [&_strong]:text-charcoal
      ">
        <Content />
      </div>
    </div>
  </section>

  <!-- Related models -->
  {relatedModels.length > 0 && (
    <section class="section-padding bg-stone">
      <div class="container-narrow">
        <h2 class="text-2xl font-bold text-charcoal mb-8" data-animate="fade-up">
          {entry.data.isCategory ? 'Vehicles we fit out' : 'Other vehicles in this category'}
        </h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6" data-animate="stagger">
          {relatedModels.map((model) => (
            <a href={`/services/${model.id}`} class="group bg-white rounded-xl p-6 border border-stone-dark/10 hover:border-sand/40 transition-colors">
              <h3 class="text-lg font-bold text-charcoal mb-1 group-hover:text-primary transition-colors">{model.data.title}</h3>
              {model.data.priceRange && (
                <p class="text-sm text-sand-dark font-semibold mb-2">{model.data.priceRange}</p>
              )}
              <p class="text-sm text-muted-foreground line-clamp-2">{model.data.description}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="section-padding bg-charcoal text-stone-light">
    <div class="container-narrow text-center">
      <h2 class="text-2xl sm:text-3xl font-bold mb-3" data-animate="fade-up">
        {entry.data.isCategory
          ? `Ready to build your ${entry.data.title.toLowerCase().replace(' fit-outs', '').replace(' conversions', '')} fit-out?`
          : `Get a quote for your ${entry.data.title.replace(' Fit-Out', '').replace(' fit-out', '')}`
        }
      </h2>
      <p class="text-stone-dark mb-8 max-w-lg mx-auto" data-animate="fade-up">
        Tell us about your vehicle and how you travel. We'll come back with a design and quote.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center" data-animate="fade-up">
        <a
          href={`/quote?type=${encodeURIComponent(entry.data.title)}`}
          class="inline-flex items-center justify-center px-8 py-4 bg-sand text-charcoal font-bold text-base rounded-md hover:bg-sand-light transition-colors"
        >
          Get a Free Quote
        </a>
        <a href="tel:+61424770875" class="inline-flex items-center justify-center px-8 py-4 border-2 border-stone-dark/40 text-stone-light font-semibold text-base rounded-md hover:border-sand hover:text-sand transition-colors">
          Call 0424 770 875
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
