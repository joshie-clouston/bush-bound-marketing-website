---
export const prerender = true;

import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';

const vehicles = (await getCollection('services', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);

const types = [
  { key: '4wd', label: '4WD & Wagon' },
  { key: 'troopy', label: 'Troop Carrier (Troopy)' },
  { key: 'van', label: 'Vans' },
];
---

<BaseLayout title="Vehicles We Fit Out | Bush Bound" description="Custom fit-outs for 4WDs, Troop Carriers and vans. See the full list of vehicles we build for. Gold Coast, QLD.">

  <!-- Hero -->
  <section class="section-padding bg-charcoal text-stone-light">
    <div class="container-narrow text-center">
      <p class="text-sand font-medium text-sm uppercase tracking-widest mb-4" data-animate="fade-in">What We Build</p>
      <h1 class="text-4xl sm:text-5xl font-extrabold mb-6" data-animate="fade-up">
        Vehicles we fit out
      </h1>
      <p class="text-lg text-stone/90 max-w-2xl mx-auto" data-animate="fade-up">
        Whether you're setting up for weekend camping trips, building a Troop Carrier for a lap of Australia, or converting your van into a home on wheels, we've got you covered.
      </p>
    </div>
  </section>

  <!-- Vehicle Grid -->
  <section class="section-padding bg-background">
    <div class="container-narrow">
      {types.map((type) => {
        const typeVehicles = vehicles.filter(v => v.data.category === type.key);
        if (typeVehicles.length === 0) return null;
        return (
          <div class="mb-12 last:mb-0">
            <h2 class="text-2xl font-bold text-charcoal mb-6" data-animate="fade-up">{type.label}</h2>
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4" data-animate="fade-up">
              {typeVehicles.map((vehicle) => (
                <a href={`/services/${vehicle.id}`} class="group bg-white rounded-xl p-6 border border-stone-dark/10 hover:border-primary/30 hover:shadow-sm transition-all">
                  <span class="inline-flex items-center px-2.5 py-0.5 bg-primary/10 text-primary text-xs font-semibold rounded-full mb-3">{type.label}</span>
                  <h3 class="text-lg font-bold text-charcoal mb-1 group-hover:text-primary transition-colors">{vehicle.data.title}</h3>
                  <p class="text-sm text-muted-foreground line-clamp-2 mb-3">{vehicle.data.description}</p>
                  <span class="text-primary text-sm font-medium group-hover:underline">View details &rarr;</span>
                </a>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <!-- CTA -->
  <section class="relative overflow-hidden">
    <div class="bg-gradient-to-br from-primary-dark via-primary to-primary-light py-16 sm:py-20">
      <div class="container-narrow text-center relative z-10">
        <h2 class="text-3xl sm:text-4xl font-bold text-primary-foreground mb-4">
          Don't see your vehicle?
        </h2>
        <p class="text-stone-light/80 text-lg mb-8 max-w-lg mx-auto">
          We fit out most 4WDs, vans and utes. Tell us what you drive and we'll let you know what's possible.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/quote" class="inline-flex items-center justify-center px-8 py-4 bg-sand text-charcoal font-bold text-base rounded-md hover:bg-sand-light transition-colors">
            Get a Free Quote
          </a>
          <a href="tel:+61424770875" class="inline-flex items-center justify-center px-8 py-4 border-2 border-stone-light/30 text-stone-light font-semibold text-base rounded-md hover:border-sand hover:text-sand transition-colors">
            Call 0424 770 875
          </a>
        </div>
      </div>
      <div class="absolute top-0 left-0 w-64 h-64 bg-white/5 rounded-full -translate-x-1/2 -translate-y-1/2"></div>
      <div class="absolute bottom-0 right-0 w-48 h-48 bg-white/5 rounded-full translate-x-1/3 translate-y-1/3"></div>
    </div>
  </section>

</BaseLayout>
