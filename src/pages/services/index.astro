---
export const prerender = true;

import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';

const services = (await getCollection('services', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);

const categories = services.filter(s => s.data.isCategory);
const models = services.filter(s => !s.data.isCategory);

// Group model pages by their parent category
const modelsByCategory = Object.groupBy(models, (s) => s.data.parentCategory ?? '');
---

<BaseLayout title="Vehicle Fit-Out Services | Bush Bound" description="Custom fit-outs for Troopies, vans and 4WDs. CNC-cut plywood, 3D design, off-grid power and water systems. Gold Coast, QLD.">

  <!-- Hero -->
  <section class="section-padding bg-charcoal text-stone-light">
    <div class="container-narrow text-center">
      <p class="text-sand font-medium text-sm uppercase tracking-widest mb-4" data-animate="fade-in">What We Build</p>
      <h1 class="text-4xl sm:text-5xl font-extrabold mb-6" data-animate="fade-up">
        Vehicle fit-out services
      </h1>
      <p class="text-lg text-stone/90 max-w-2xl mx-auto" data-animate="fade-up">
        Custom builds for Troopies, vans and 4WDs. Every fit-out is designed in 3D, CNC-cut from premium plywood, and professionally installed in our Gold Coast workshop.
      </p>
    </div>
  </section>

  <!-- Category Cards -->
  <section class="section-padding bg-background">
    <div class="container-narrow">
      <div class="grid md:grid-cols-3 gap-8" data-animate="stagger">
        {categories.map((cat) => {
          const catModels = modelsByCategory[cat.id] ?? [];
          return (
            <a href={`/services/${cat.id}`} class="group bg-white rounded-xl p-8 border border-stone-dark/10 hover:border-sand/40 transition-colors">
              <h2 class="text-2xl font-bold text-charcoal mb-2 group-hover:text-primary transition-colors">{cat.data.title}</h2>
<p class="text-muted-foreground text-sm leading-relaxed mb-4">{cat.data.description}</p>
              {catModels.length > 0 && (
                <ul class="text-sm text-muted-foreground space-y-1">
                  {catModels.map((m) => (
                    <li class="flex items-center gap-2">
                      <span class="text-primary">&#10003;</span>
                      {m.data.title}
                    </li>
                  ))}
                </ul>
              )}
              <p class="text-primary font-semibold text-sm mt-4 group-hover:underline">
                View details &rarr;
              </p>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- All Models Grid -->
  <section class="section-padding bg-stone">
    <div class="container-narrow">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-charcoal" data-animate="fade-up">Vehicles we fit out</h2>
        <p class="text-muted-foreground mt-3 max-w-xl mx-auto" data-animate="fade-up">
          Click any vehicle below for specific details, pricing, and what's included.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6" data-animate="stagger">
        {models.map((model) => (
          <a href={`/services/${model.id}`} class="group bg-white rounded-xl p-6 border border-stone-dark/10 hover:border-sand/40 transition-colors">
            <p class="text-xs font-semibold text-sand-dark uppercase tracking-wider mb-2">{model.data.categoryLabel}</p>
            <h3 class="text-lg font-bold text-charcoal mb-1 group-hover:text-primary transition-colors">{model.data.title}</h3>
<p class="text-sm text-muted-foreground line-clamp-2">{model.data.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding bg-charcoal text-stone-light">
    <div class="container-narrow text-center">
      <h2 class="text-2xl sm:text-3xl font-bold mb-3" data-animate="fade-up">Not sure which fit-out you need?</h2>
      <p class="text-stone-dark mb-8 max-w-lg mx-auto" data-animate="fade-up">
        Tell us about your vehicle and how you travel. We'll recommend the best setup for your budget.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center" data-animate="fade-up">
        <a href="/quote?type=consultation" class="inline-flex items-center justify-center px-8 py-4 bg-sand text-charcoal font-bold text-base rounded-md hover:bg-sand-light transition-colors">
          Book a Free Consultation
        </a>
        <a href="tel:+61424770875" class="inline-flex items-center justify-center px-8 py-4 border-2 border-stone-dark/40 text-stone-light font-semibold text-base rounded-md hover:border-sand hover:text-sand transition-colors">
          Call 0424 770 875
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
