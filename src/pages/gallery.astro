---
export const prerender = true;

import BaseLayout from '@/layouts/BaseLayout.astro';
import { reviews } from '@/data/reviews';

const categories = [
  { key: 'troopy', label: 'Troop Carrier (Troopy)', tags: ['Troop Carrier (Troopy)'] },
  { key: '4wd', label: '4WD & Wagon', tags: ['100 Series', '80 Series', '76 Series'] },
  { key: 'van', label: 'Vans', tags: ['Transporter', 'Multivan', 'Hiace'] },
  { key: 'other', label: 'Other', tags: ['Silverado', 'Prado'] },
];

// Group reviews by category
function getCategory(review: typeof reviews[0]) {
  for (const cat of categories) {
    if (review.tags.some(t => cat.tags.some(ct => t.includes(ct)))) return cat.key;
  }
  return 'other';
}

const grouped = categories.map(cat => ({
  ...cat,
  reviews: reviews.filter(r => getCategory(r) === cat.key),
})).filter(g => g.reviews.length > 0);
---

<BaseLayout title="Gallery | Vehicle Fit-Out Photos | Bush Bound" description="Browse photos of custom vehicle fit-outs by Bush Bound. Troop Carriers, 4WDs and vans. Gold Coast, QLD.">

  <section class="section-padding bg-background">
    <div class="container-wide">
      <a href="/" class="inline-flex items-center text-sm text-primary font-medium mb-6 hover:text-primary-light transition-colors">
        <svg class="w-4 h-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        Back to home
      </a>

      <div class="text-center mb-12">
        <p class="text-sand-dark font-medium text-sm uppercase tracking-widest mb-3">Gallery</p>
        <h1 class="text-3xl sm:text-4xl font-bold text-charcoal mb-4">
          Fit-out photo gallery
        </h1>
        <p class="text-muted-foreground text-lg max-w-2xl mx-auto">
          Browse photos from our builds. Click any image to see the full review and all photos from that build.
        </p>
      </div>

      {grouped.map((group) => (
        <div class="mb-16 last:mb-0">
          <h2 class="text-2xl font-bold text-charcoal mb-6">{group.label}</h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
            {group.reviews.flatMap((review) =>
              review.images.slice(0, group.key === 'other' ? 6 : 4).map((img) => (
                <a href={`/reviews/${review.slug}`} class="group rounded-xl overflow-hidden bg-stone aspect-square">
                  <img
                    src={img}
                    alt={`${review.name}'s ${review.vehicle} fit-out`}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                  />
                </a>
              ))
            )}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="relative overflow-hidden">
    <div class="bg-gradient-to-br from-primary-dark via-primary to-primary-light py-16 sm:py-20">
      <div class="container-narrow text-center relative z-10">
        <div class="flex items-center justify-center gap-1.5 mb-6">
          {[1,2,3,4,5].map(() => (
            <svg class="w-5 h-5 text-sand" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>
        <h2 class="text-3xl sm:text-4xl font-bold text-primary-foreground mb-4">
          Want a build like these?
        </h2>
        <p class="text-stone-light/80 text-lg mb-8 max-w-lg mx-auto">
          Tell us about your vehicle and we'll give you a call to talk through the design.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/quote" class="inline-flex items-center justify-center px-8 py-4 bg-sand text-charcoal font-bold text-base rounded-md hover:bg-sand-light transition-colors">
            Get a Free Quote
          </a>
          <a href="/reviews" class="inline-flex items-center justify-center px-8 py-4 border-2 border-stone-light/30 text-stone-light font-semibold text-base rounded-md hover:border-sand hover:text-sand transition-colors">
            Read Reviews
          </a>
        </div>
      </div>
      <div class="absolute top-0 left-0 w-64 h-64 bg-white/5 rounded-full -translate-x-1/2 -translate-y-1/2"></div>
      <div class="absolute bottom-0 right-0 w-48 h-48 bg-white/5 rounded-full translate-x-1/3 translate-y-1/3"></div>
    </div>
  </section>

</BaseLayout>
