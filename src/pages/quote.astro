---
export const prerender = true;

import BaseLayout from '@/layouts/BaseLayout.astro';

const reviewQuotes = [
  { text: "Highly recommend going with Bush Bound to just get it done right the first time.", name: "Joshua C.", vehicle: "Troop Carrier" },
  { text: "Absolutely nailed it. Attention to detail is what sets them apart.", name: "Luke W.", vehicle: "VW Transporter" },
  { text: "Deadset legend. Workmanship is top quality and materials are top notch!", name: "Mick D.", vehicle: "Troop Carrier" },
  { text: "Super high attention to detail, quick turn around time, and clear communication.", name: "Brock C.", vehicle: "100 Series" },
];

const checklistItems = {
  'Storage & Sleeping': [
    { id: 'drawers', label: 'Drawer system' },
    { id: 'bed', label: 'Bed / sleeping platform' },
    { id: 'rooftop-tent', label: 'Rooftop tent / awning' },
    { id: 'camping-table', label: 'Collapsable camping table' },
  ],
  'Power & Electrical': [
    { id: '12v', label: '12V dual-battery system' },
    { id: 'solar', label: 'Solar panels' },
    { id: 'inverter', label: 'Inverter (240V - laptops, chargers)' },
    { id: 'compressor', label: 'Air compressor' },
    { id: 'uhf', label: 'UHF radio & aerial install' },
    { id: 'lighting', label: 'LED lighting' },
  ],
  'Fridge & Kitchen': [
    { id: 'fridge', label: 'Fridge / freezer' },
    { id: 'kitchen', label: 'Slide-out kitchen / bench' },
    { id: 'sink', label: 'Kitchen sink' },
    { id: 'cooktop', label: 'Gas cooktop' },
  ],
  'Water': [
    { id: 'watertank', label: 'Water tank' },
    { id: 'hotwater', label: 'Hot water system' },
    { id: 'shower', label: 'Outdoor shower' },
    { id: 'water-filtration', label: 'Water filtration' },
  ],
  'Recovery & Accessories': [
    { id: 'winch', label: 'Winch' },
    { id: 'recovery', label: 'Recovery gear storage' },
    { id: 'bullbar', label: 'Bull bar / rear bar' },
    { id: 'spotlights', label: 'Spotlights / light bar' },
  ],
  'Finishing': [
    { id: 'marinecarpet', label: 'Marine carpet lining' },
    { id: 'plywood', label: 'Premium ply (black, white, timber)' },
    { id: 'insulation', label: 'Insulation / sound deadening' },
    { id: 'lacquer', label: 'Hand-lacquered waterproof finish' },
  ],
};

const starPath = "M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z";
---

<BaseLayout title="Get a Free Quote | Bush Bound" description="Tell us about your vehicle and what you want. We'll call you within 48 hours for a free consultation to talk through your build.">

  <section class="section-padding bg-background">
    <div class="container-wide">
      <a href="/" class="inline-flex items-center text-sm text-primary font-medium mb-6 hover:text-primary-light transition-colors">
        <svg class="w-4 h-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        Back to home
      </a>

      <div class="flex flex-col lg:flex-row gap-10 lg:gap-16">

        <!-- Left: Form -->
        <div class="lg:w-3/5">
          <h1 class="text-3xl sm:text-4xl font-bold text-charcoal mb-2">
            Get a free quote
          </h1>
          <p class="text-muted-foreground text-lg mb-8">
            Tell us about your vehicle and what you're after. We'll give you a call within 48 hours for a free phone consult to discuss designs and give you a rough quote.
          </p>

          <form id="quote-form" class="bg-white rounded-xl border border-stone-dark/10 p-6 sm:p-8">
            <!-- Step 1: About You -->
            <div id="step-1" class="space-y-5">
              <p class="text-xs font-semibold text-sand-dark uppercase tracking-wider mb-1">Step 1 of 3 - About you</p>

              <div>
                <label for="name" class="block text-sm font-semibold text-charcoal mb-1.5">Name *</label>
                <input type="text" id="name" name="name" required class="w-full px-4 py-3 rounded-md border border-stone-dark/20 bg-stone/30 text-charcoal placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary transition-colors" placeholder="Your name" />
              </div>

              <div>
                <label for="email" class="block text-sm font-semibold text-charcoal mb-1.5">Email *</label>
                <input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-md border border-stone-dark/20 bg-stone/30 text-charcoal placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary transition-colors" placeholder="you@example.com" />
                <p id="email-error" class="hidden text-xs text-red-500 mt-1">Enter a valid email address</p>
              </div>

              <div>
                <label for="phone" class="block text-sm font-semibold text-charcoal mb-1.5">Phone *</label>
                <input type="tel" id="phone" name="phone" required pattern="^(\+?61|0)4\d{2}\s?\d{3}\s?\d{3}$" title="Enter a valid Australian mobile number (e.g. 0412 345 678)" class="w-full px-4 py-3 rounded-md border border-stone-dark/20 bg-stone/30 text-charcoal placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary transition-colors" placeholder="04XX XXX XXX" />
                <p id="phone-error" class="hidden text-xs text-red-500 mt-1">Enter a valid Australian mobile number (e.g. 0412 345 678)</p>
              </div>

              <div>
                <label for="vehicle" class="block text-sm font-semibold text-charcoal mb-1.5">What's your vehicle? *</label>
                <input type="text" id="vehicle" name="vehicle" required class="w-full px-4 py-3 rounded-md border border-stone-dark/20 bg-stone/30 text-charcoal placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary transition-colors" placeholder="e.g. Toyota Land Cruiser 78 Series, VW Transporter T6, Hilux with canopy" />
              </div>

              <button type="button" id="next-to-2" class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-3 bg-primary text-primary-foreground font-semibold rounded-md hover:bg-primary-light transition-colors">
                Next: What do you want?
                <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
              </button>
            </div>

            <!-- Step 2: What You Want -->
            <div id="step-2" class="hidden">
              <p class="text-xs font-semibold text-sand-dark uppercase tracking-wider mb-4">Step 2 of 3 - Build your wish list</p>
              <p class="text-sm text-muted-foreground mb-6">Tick everything you're interested in. Don't stress if you're not sure on some items. We'll talk through it all on the call.</p>

              <div class="space-y-6">
                <!-- Budget -->
                <div>
                  <h3 class="text-sm font-bold text-charcoal uppercase tracking-wider mb-3">Budget</h3>
                  <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
                    {[
                      { value: 'under-5k', label: 'Under $5K' },
                      { value: '5k-25k', label: '$5K - $25K' },
                      { value: '25k-50k', label: '$25K - $50K' },
                      { value: '50k-plus', label: '$50K+' },
                    ].map((opt) => (
                      <label class="flex items-center justify-center p-3 rounded-lg border border-stone-dark/30 bg-white hover:border-primary/40 hover:bg-primary/5 transition-colors cursor-pointer has-[:checked]:border-primary has-[:checked]:bg-primary/10 text-center">
                        <input type="radio" name="budget" value={opt.value} class="sr-only" />
                        <span class="text-sm text-charcoal">{opt.label}</span>
                      </label>
                    ))}
                  </div>
                </div>

                <!-- Timeline -->
                <div>
                  <h3 class="text-sm font-bold text-charcoal uppercase tracking-wider mb-3">Timeline</h3>
                  <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
                    {[
                      { value: 'planning', label: 'Just planning' },
                      { value: '6-months', label: 'Within 6 months' },
                      { value: '3-months', label: 'Within 3 months' },
                      { value: 'asap', label: 'ASAP' },
                    ].map((opt) => (
                      <label class="flex items-center justify-center p-3 rounded-lg border border-stone-dark/30 bg-white hover:border-primary/40 hover:bg-primary/5 transition-colors cursor-pointer has-[:checked]:border-primary has-[:checked]:bg-primary/10 text-center">
                        <input type="radio" name="timeline" value={opt.value} class="sr-only" />
                        <span class="text-sm text-charcoal">{opt.label}</span>
                      </label>
                    ))}
                  </div>
                </div>

                <!-- Feature checklist -->
                {Object.entries(checklistItems).map(([category, items]) => (
                  <div>
                    <h3 class="text-sm font-bold text-charcoal uppercase tracking-wider mb-3">{category}</h3>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                      {items.map((item) => (
                        <label class="flex items-center gap-3 p-3 rounded-lg border border-stone-dark/30 bg-white hover:border-primary/40 hover:bg-primary/5 transition-colors cursor-pointer has-[:checked]:border-primary has-[:checked]:bg-primary/10">
                          <input type="checkbox" name="features" value={item.id} class="w-4 h-4 rounded border-stone-dark/30 text-primary focus:ring-primary/40" />
                          <span class="text-sm text-charcoal">{item.label}</span>
                        </label>
                      ))}
                    </div>
                  </div>
                ))}
              </div>

              <div class="flex gap-3 mt-8">
                <button type="button" id="back-to-1" class="inline-flex items-center justify-center px-6 py-3 border-2 border-stone-dark/20 text-charcoal font-semibold rounded-md hover:border-primary hover:text-primary transition-colors">
                  <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" /></svg>
                  Back
                </button>
                <button type="button" id="next-to-3" class="flex-1 sm:flex-none inline-flex items-center justify-center px-8 py-3 bg-primary text-primary-foreground font-semibold rounded-md hover:bg-primary-light transition-colors">
                  Next: Final details
                  <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
                </button>
              </div>
            </div>

            <!-- Step 3: Final Details -->
            <div id="step-3" class="hidden space-y-5">
              <p class="text-xs font-semibold text-sand-dark uppercase tracking-wider mb-1">Step 3 of 3 - Final details</p>

              <div>
                <label for="message" class="block text-sm font-semibold text-charcoal mb-1.5">Anything specific you want us to know?</label>
                <textarea id="message" name="message" rows="4" class="w-full px-4 py-3 rounded-md border border-stone-dark/30 bg-white text-charcoal placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary transition-colors resize-y" placeholder="Tell us how you use your vehicle, where you travel, or anything else that would help us design the perfect build for you."></textarea>
              </div>

              <div>
                <label for="referral" class="block text-sm font-semibold text-charcoal mb-1.5">How did you hear about us?</label>
                <select id="referral" name="referral" class="w-full px-4 py-3 rounded-md border border-stone-dark/30 bg-white text-charcoal focus:outline-none focus:ring-2 focus:ring-primary/40 focus:border-primary transition-colors">
                  <option value="">Select one</option>
                  <option value="instagram">Instagram</option>
                  <option value="facebook">Facebook</option>
                  <option value="tiktok">TikTok</option>
                  <option value="google">Google search</option>
                  <option value="word-of-mouth">Word of mouth</option>
                  <option value="other">Other</option>
                </select>
              </div>

              <div class="flex gap-3">
                <button type="button" id="back-to-2" class="inline-flex items-center justify-center px-6 py-3 border-2 border-stone-dark/20 text-charcoal font-semibold rounded-md hover:border-primary hover:text-primary transition-colors">
                  <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" /></svg>
                  Back
                </button>
                <button type="submit" class="flex-1 sm:flex-none inline-flex items-center justify-center px-8 py-3 bg-sand text-charcoal font-bold rounded-md hover:bg-sand-light transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
                  <span id="submit-text">Send Quote Request</span>
                  <svg id="submit-spinner" class="hidden w-5 h-5 ml-2 animate-spin" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                  </svg>
                </button>
              </div>
            </div>
          </form>

          <!-- Success message -->
          <div id="success-message" class="hidden mt-8 p-8 bg-primary/10 border border-primary/20 rounded-xl text-center">
            <svg class="w-12 h-12 text-primary mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <h3 class="text-xl font-bold text-charcoal mb-1">Quote request sent!</h3>
            <p class="text-muted-foreground">We'll give you a call within 48 hours to talk through your build. Keep an eye on your inbox for a confirmation email.</p>
          </div>

          <!-- Error message -->
          <div id="error-message" class="hidden mt-8 p-6 bg-red-50 border border-red-200 rounded-xl text-center">
            <h3 class="text-xl font-bold text-charcoal mb-1">Something went wrong</h3>
            <p class="text-muted-foreground">Please try again or call us directly on <a href="tel:+61424770875" class="text-primary underline">0424 770 875</a></p>
          </div>
        </div>

        <!-- Right: Social Proof Sidebar -->
        <div class="lg:w-2/5">
          <div class="sticky top-28 space-y-6">
            <!-- Why Bush Bound -->
            <div class="bg-white rounded-xl border border-stone-dark/10 p-6">
              <h3 class="font-bold text-charcoal mb-4">Why Bush Bound?</h3>
              <ul class="space-y-3 text-sm text-muted-foreground">
                <li class="flex gap-3">
                  <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                  <span>Full 3D design so you see your build before we start</span>
                </li>
                <li class="flex gap-3">
                  <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                  <span>CNC-cut premium plywood, built to last</span>
                </li>
                <li class="flex gap-3">
                  <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                  <span>12-month warranty on every build</span>
                </li>
                <li class="flex gap-3">
                  <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                  <span>Gold Coast workshop, professional install</span>
                </li>
              </ul>
            </div>

            <!-- Review carousel -->
            <div class="bg-white rounded-xl border border-stone-dark/10 p-6">
              <div class="flex items-center gap-1 mb-4">
                {[1,2,3,4,5].map(() => (
                  <svg class="w-4 h-4 text-sand" fill="currentColor" viewBox="0 0 20 20"><path d={starPath}/></svg>
                ))}
              </div>
              <div id="sidebar-reviews" class="relative min-h-[80px]">
                {reviewQuotes.map((r, i) => (
                  <div class:list={['sidebar-review transition-opacity duration-500 absolute inset-0', i === 0 ? 'opacity-100' : 'opacity-0']}>
                    <p class="text-sm text-charcoal italic mb-2">"{r.text}"</p>
                    <p class="text-xs text-muted-foreground">{r.name}, {r.vehicle}</p>
                  </div>
                ))}
              </div>
              <a href="/reviews" class="inline-flex items-center text-sm text-primary font-medium mt-4 hover:underline">
                See all customer builds
                <svg class="w-3.5 h-3.5 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
              </a>
            </div>

            <!-- Build photo carousel -->
            <div class="rounded-xl overflow-hidden border border-stone-dark/10">
              <div class="relative aspect-[4/3]">
                {[
                  { src: '/images/reviews/toyota-landcruiser-troopcarrier-jack-1.webp', href: '/reviews/jack-f-troopy' },
                  { src: '/images/reviews/toyota-landcruiser-troopcarrier-2-1.webp', href: '/reviews/mick-d-troopy' },
                  { src: '/images/reviews/volkswagen-multivan-3.webp', href: '/reviews/luke-w-transporter' },
                  { src: '/images/reviews/toyota-bush-bound-80-series-4.webp', href: '/reviews/luke-c-80-series' },
                  { src: '/images/reviews/toyota-100-series-jai-1.webp', href: '/reviews/jai-g-100-series' },
                  { src: '/images/reviews/toyota-100-series-1.webp', href: '/reviews/brock-c-100-series' },
                  { src: '/images/reviews/toyota-landcruiser-troopcarrier-white-6.webp', href: '/reviews/norman-h-troopy' },
                  { src: '/images/reviews/toyota-landcruiser-troopcarrier-1-2.webp', href: '/reviews/joshua-c-troopy' },
                ].map((img, i) => (
                  <a href={img.href} class:list={['sidebar-build absolute inset-0 transition-opacity duration-1000', i === 0 ? 'opacity-100' : 'opacity-0 pointer-events-none']}>
                    <img src={img.src} alt="Bush Bound fit-out" class="w-full h-full object-cover" loading="lazy" />
                  </a>
                ))}
              </div>
              <a href="/reviews" class="block p-4 bg-white hover:bg-stone/30 transition-colors">
                <p class="text-sm font-semibold text-charcoal">See our latest builds</p>
                <p class="text-xs text-muted-foreground">Happy customers, bush bound</p>
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <script>
    // Multi-step navigation
    const step1 = document.getElementById('step-1')!;
    const step2 = document.getElementById('step-2')!;
    const step3 = document.getElementById('step-3')!;

    function showStep(show: HTMLElement, hide1: HTMLElement, hide2: HTMLElement) {
      hide1.classList.add('hidden');
      hide2.classList.add('hidden');
      show.classList.remove('hidden');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // Prevent Enter from submitting on steps 1 and 2
    const quoteForm = document.getElementById('quote-form') as HTMLFormElement;
    quoteForm?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !step3.classList.contains('hidden')) return; // allow on step 3
      if (e.key === 'Enter' && (e.target as HTMLElement)?.tagName !== 'TEXTAREA') {
        e.preventDefault();
        // Trigger the visible Next button instead
        if (!step1.classList.contains('hidden')) document.getElementById('next-to-2')?.click();
        else if (!step2.classList.contains('hidden')) document.getElementById('next-to-3')?.click();
      }
    });

    // Step 1 validation + submit lead
    const emailError = document.getElementById('email-error')!;
    const phoneError = document.getElementById('phone-error')!;
    const ausMobileRegex = /^(\+?61|0)4\d{2}\s?\d{3}\s?\d{3}$/;
    let leadId: string | null = null;

    document.getElementById('next-to-2')?.addEventListener('click', async () => {
      const name = document.getElementById('name') as HTMLInputElement;
      const email = document.getElementById('email') as HTMLInputElement;
      const phone = document.getElementById('phone') as HTMLInputElement;
      const vehicle = document.getElementById('vehicle') as HTMLInputElement;

      emailError.classList.add('hidden');
      phoneError.classList.add('hidden');

      if (!name.value || !email.value || !phone.value || !vehicle.value) {
        [name, email, phone, vehicle].find(f => !f.value)?.focus();
        return;
      }
      if (!email.validity.valid) { emailError.classList.remove('hidden'); email.focus(); return; }
      if (!ausMobileRegex.test(phone.value.trim())) { phoneError.classList.remove('hidden'); phone.focus(); return; }

      // Submit step 1 to create lead
      try {
        const res = await fetch('/api/quote', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ step: '1', name: name.value, email: email.value, phone: phone.value, vehicle: vehicle.value }),
        });
        const json = await res.json() as Record<string, string>;
        if (json.leadId) leadId = String(json.leadId);
      } catch { /* continue even if DB fails */ }

      showStep(step2, step1, step3);
    });

    document.getElementById('back-to-1')?.addEventListener('click', () => showStep(step1, step2, step3));

    // Step 2 → Step 3: submit wishlist
    document.getElementById('next-to-3')?.addEventListener('click', async () => {
      const formData = new FormData(document.getElementById('quote-form') as HTMLFormElement);
      const features = formData.getAll('features').join(', ');
      const budget = formData.get('budget') as string || '';
      const timeline = formData.get('timeline') as string || '';

      try {
        await fetch('/api/quote', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ step: '2', leadId, serviceType: features, budget, timeline }),
        });
      } catch { /* continue */ }

      showStep(step3, step1, step2);
    });

    document.getElementById('back-to-2')?.addEventListener('click', () => showStep(step2, step1, step3));

    // Step 3: Final submit + email notification
    const form = document.getElementById('quote-form') as HTMLFormElement;
    const submitText = document.getElementById('submit-text')!;
    const submitSpinner = document.getElementById('submit-spinner')!;
    const successMessage = document.getElementById('success-message')!;
    const errorMessage = document.getElementById('error-message')!;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      const button = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      button.disabled = true;
      submitText.textContent = 'Sending...';
      submitSpinner.classList.remove('hidden');
      errorMessage.classList.add('hidden');

      const formData = new FormData(form);
      const features = formData.getAll('features').join(', ');
      const budget = formData.get('budget') as string || '';
      const timeline = formData.get('timeline') as string || '';

      // Capture UTM params
      const utmParams = new URLSearchParams(window.location.search);
      const utm: Record<string, string> = {};
      for (const key of ['utm_source', 'utm_medium', 'utm_campaign']) {
        const val = utmParams.get(key);
        if (val) utm[key] = val;
      }

      try {
        const res = await fetch('/api/quote', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            step: '3',
            leadId,
            name: formData.get('name'),
            email: formData.get('email'),
            phone: formData.get('phone'),
            vehicle: formData.get('vehicle'),
            serviceType: features,
            budget,
            timeline,
            message: formData.get('message') || '',
            referral: formData.get('referral') || '',
            ...utm,
          }),
        });

        if (!res.ok) throw new Error('Failed');

        form.classList.add('hidden');
        successMessage.classList.remove('hidden');
      } catch {
        errorMessage.classList.remove('hidden');
        button.disabled = false;
        submitText.textContent = 'Send Quote Request';
        submitSpinner.classList.add('hidden');
      }
    });

    // Sidebar review carousel
    const sidebarReviews = document.querySelectorAll('.sidebar-review');
    if (sidebarReviews.length > 1) {
      let currentReview = 0;
      setInterval(() => {
        const next = (currentReview + 1) % sidebarReviews.length;
        (sidebarReviews[currentReview] as HTMLElement).style.opacity = '0';
        (sidebarReviews[next] as HTMLElement).style.opacity = '1';
        currentReview = next;
      }, 5000);
    }

    // Sidebar build photo carousel
    const sidebarBuilds = document.querySelectorAll('.sidebar-build');
    if (sidebarBuilds.length > 1) {
      let currentBuild = 0;
      setInterval(() => {
        const next = (currentBuild + 1) % sidebarBuilds.length;
        (sidebarBuilds[currentBuild] as HTMLElement).style.opacity = '0';
        (sidebarBuilds[currentBuild] as HTMLElement).classList.add('pointer-events-none');
        (sidebarBuilds[next] as HTMLElement).style.opacity = '1';
        (sidebarBuilds[next] as HTMLElement).classList.remove('pointer-events-none');
        currentBuild = next;
      }, 4000);
    }
  </script>

</BaseLayout>
