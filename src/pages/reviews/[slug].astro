---
export const prerender = true;

import BaseLayout from '@/layouts/BaseLayout.astro';
import { reviews } from '@/data/reviews';

export function getStaticPaths() {
  return reviews.map((review) => ({
    params: { slug: review.slug },
    props: { review },
  }));
}

const { review } = Astro.props;
const firstName = review.name.split(' ')[0];
---

<BaseLayout
  title={`${review.vehicle} Fit-Out Review - ${review.name} | Bush Bound`}
  description={`${review.vehicle} fit-out review by Bush Bound. ${review.brief}`}
>
  <section class="section-padding bg-background">
    <div class="container-narrow">
      <a href="/reviews" class="inline-flex items-center text-sm text-primary font-medium mb-8 hover:text-primary-light transition-colors">
        <svg class="w-4 h-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        All reviews
      </a>

      <!-- Header -->
      <div class="mb-10">
        <div class="flex flex-wrap gap-2 mb-3">
          {review.tags.map((tag: string) => (
            <span class="inline-flex items-center px-3 py-1 bg-primary/10 text-primary text-xs font-semibold rounded-full">{tag}</span>
          ))}
        </div>
        <h1 class="text-3xl sm:text-4xl font-bold text-charcoal">
          {review.vehicle} Fit-Out Review - {review.name}
        </h1>
      </div>

      <!-- What they asked for -->
      <div class="bg-white rounded-xl border border-stone-dark/10 p-8 mb-8">
        <div class="flex items-center gap-2 mb-4">
          <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" />
          </svg>
          <span class="text-sm font-semibold text-charcoal uppercase tracking-wider">What {firstName} asked for</span>
        </div>
        <blockquote class="text-lg text-charcoal leading-relaxed italic">
          &ldquo;{review.brief}&rdquo;
        </blockquote>
      </div>

      <!-- Photo gallery -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-8">
        {review.images.map((img: string, i: number) => (
          <div class:list={[
            'rounded-xl overflow-hidden bg-stone',
            i === 0 ? 'sm:col-span-2 aspect-video' : 'aspect-[4/3]'
          ]}>
            <img
              src={img}
              alt={`${review.name}'s ${review.vehicle} fit-out - photo ${i + 1}`}
              class="w-full h-full object-cover"
              loading={i === 0 ? 'eager' : 'lazy'}
            />
          </div>
        ))}
      </div>

      <!-- Google Review -->
      <div class="bg-white rounded-xl border border-stone-dark/10 p-8 mb-12">
        <div class="flex items-center gap-1.5 mb-4">
          {[1,2,3,4,5].map(() => (
            <svg class="w-5 h-5 text-sand" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
          <span class="text-sm text-muted-foreground ml-2">Google Review</span>
        </div>
        <blockquote class="text-lg text-charcoal leading-relaxed italic">
          &ldquo;{review.testimonial}&rdquo;
        </blockquote>
        <p class="mt-4 font-semibold text-charcoal">{review.name}</p>
      </div>

    </div>
  </section>

  <!-- CTA Banner -->
  <section class="relative overflow-hidden" data-animate="fade-up">
    <div class="bg-gradient-to-br from-primary-dark via-primary to-primary-light py-16 sm:py-20">
      <div class="container-narrow text-center relative z-10">
        <!-- Social proof -->
        <div class="flex items-center justify-center gap-1.5 mb-6">
          {[1,2,3,4,5].map(() => (
            <svg class="w-5 h-5 text-sand" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>

        <h2 class="text-3xl sm:text-4xl font-bold text-primary-foreground mb-4">
          Want a build like this?
        </h2>
        <p class="text-stone-light/80 text-lg mb-8 max-w-lg mx-auto">
          Tell us about your vehicle and we'll give you a call to talk through the design and build something perfect for you.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/quote" class="inline-flex items-center justify-center px-8 py-4 bg-sand text-charcoal font-bold text-base rounded-md hover:bg-sand-light transition-colors">
            Get a Free Quote
          </a>
          <a href="/quote?type=consultation" class="inline-flex items-center justify-center px-8 py-4 border-2 border-stone-light/30 text-stone-light font-semibold text-base rounded-md hover:border-sand hover:text-sand transition-colors">
            Book a Consultation
          </a>
        </div>
      </div>

      <!-- Subtle decorative elements -->
      <div class="absolute top-0 left-0 w-64 h-64 bg-white/5 rounded-full -translate-x-1/2 -translate-y-1/2"></div>
      <div class="absolute bottom-0 right-0 w-48 h-48 bg-white/5 rounded-full translate-x-1/3 translate-y-1/3"></div>
    </div>
  </section>
</BaseLayout>
