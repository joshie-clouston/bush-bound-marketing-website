---
export const prerender = true;

import BaseLayout from '@/layouts/BaseLayout.astro';
import { reviews } from '@/data/reviews';

export function getStaticPaths() {
  return reviews.map((review) => ({
    params: { slug: review.slug },
    props: { review },
  }));
}

const { review } = Astro.props;
---

<BaseLayout
  title={`${review.name} ${review.vehicle} Fit-Out | Bushbound Reviews`}
  description={`${review.name}'s custom ${review.vehicle} fit-out by Bushbound. ${review.brief}`}
>
  <section class="section-padding bg-background">
    <div class="container-narrow">
      <a href="/reviews" class="inline-flex items-center text-sm text-primary font-medium mb-8 hover:text-primary-light transition-colors">
        <svg class="w-4 h-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        All reviews
      </a>

      <!-- Header -->
      <div class="mb-10">
        <div class="flex flex-wrap gap-2 mb-3">
          {review.tags.map((tag: string) => (
            <span class="inline-flex items-center px-3 py-1 bg-primary/10 text-primary text-xs font-semibold rounded-full">{tag}</span>
          ))}
        </div>
        <h1 class="text-3xl sm:text-4xl font-bold text-charcoal mb-2">
          {review.name}&rsquo;s {review.vehicle}
        </h1>
        <p class="text-muted-foreground text-lg">{review.brief}</p>
      </div>

      <!-- Photo gallery -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-12">
        {review.images.map((img: string, i: number) => (
          <div class:list={[
            'rounded-xl overflow-hidden bg-stone',
            i === 0 ? 'sm:col-span-2 aspect-video' : 'aspect-[4/3]'
          ]}>
            <img
              src={img}
              alt={`${review.name}'s ${review.vehicle} fit-out - photo ${i + 1}`}
              class="w-full h-full object-cover"
              loading={i === 0 ? 'eager' : 'lazy'}
            />
          </div>
        ))}
      </div>

      <!-- Review -->
      <div class="bg-white rounded-xl border border-stone-dark/10 p-8 mb-12">
        <div class="flex items-center gap-1.5 mb-4">
          {[1,2,3,4,5].map(() => (
            <svg class="w-5 h-5 text-sand" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
          <span class="text-sm text-muted-foreground ml-2">Google Review</span>
        </div>
        <blockquote class="text-lg text-charcoal leading-relaxed italic">
          &ldquo;{review.testimonial}&rdquo;
        </blockquote>
        <p class="mt-4 font-semibold text-charcoal">{review.name}</p>
      </div>

      <!-- CTA -->
      <div class="text-center" data-animate="fade-up">
        <h2 class="text-2xl font-bold text-charcoal mb-3">Want a build like this?</h2>
        <p class="text-muted-foreground mb-6">Tell us about your vehicle and we'll design something custom for you.</p>
        <a href="/quote" class="inline-flex items-center justify-center px-8 py-4 bg-primary text-primary-foreground font-bold rounded-md hover:bg-primary-light transition-colors">
          Get a Free Quote
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
