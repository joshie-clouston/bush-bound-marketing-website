---
export const prerender = true;

import BaseLayout from '@/layouts/BaseLayout.astro';
import { reviews } from '@/data/reviews';
---

<BaseLayout title="Bush Bound Reviews | Customer Fit-Out Testimonials" description="Read real reviews from Bush Bound customers. 5-star Google reviews for custom 4WD, Troop Carrier (Troopy) and van fit-outs on the Gold Coast.">

  <section class="section-padding bg-background">
    <div class="container-wide">
      <a href="/" class="inline-flex items-center text-sm text-primary font-medium mb-8 hover:text-primary-light transition-colors">
        <svg class="w-4 h-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        Back to home
      </a>

      <div class="text-center mb-16">
        <p class="text-sand-dark font-medium text-sm uppercase tracking-widest mb-3">Testimonials</p>
        <h1 class="text-3xl sm:text-4xl font-bold text-charcoal mb-4">
          Bush Bound Reviews
        </h1>
        <p class="text-muted-foreground text-lg max-w-2xl mx-auto">
          Real customers, real builds, real adventures. Here's what our customers have to say about their Bush Bound fit-outs.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {reviews.map((review) => (
          <a href={`/reviews/${review.slug}`} class="group bg-white rounded-xl border border-stone-dark/10 overflow-hidden hover:shadow-lg hover:border-sand/40 transition-all">
            <div class="aspect-[4/3] bg-stone overflow-hidden">
              <img
                src={review.image}
                alt={`${review.name}'s ${review.vehicle} fit-out`}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            </div>
            <div class="p-6">
              <div class="flex flex-wrap gap-2 mb-3">
                {review.tags.map((tag) => (
                  <span class="inline-flex items-center px-2.5 py-0.5 bg-primary/10 text-primary text-xs font-semibold rounded-full">{tag}</span>
                ))}
              </div>
              <h2 class="text-lg font-bold text-charcoal mb-2">{review.name}</h2>
              <p class="text-sm text-muted-foreground line-clamp-3 italic">"{review.testimonial}"</p>
              <span class="inline-flex items-center text-sm text-primary font-medium mt-3 group-hover:underline">
                View build
                <svg class="w-3.5 h-3.5 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>

      <!-- CTA -->
      <div class="mt-16 text-center" data-animate="fade-up">
        <h2 class="text-2xl font-bold text-charcoal mb-3">Want to be next?</h2>
        <p class="text-muted-foreground mb-6">Get your fit-out sorted and join the crew.</p>
        <a href="/quote" class="inline-flex items-center justify-center px-8 py-4 bg-primary text-primary-foreground font-bold rounded-md hover:bg-primary-light transition-colors">
          Get a Free Quote
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
