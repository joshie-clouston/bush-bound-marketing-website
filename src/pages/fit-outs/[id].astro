---
export const prerender = true;

import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const services = await getCollection('services', ({ data }) => !data.draft);
  return services.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// Get other vehicles (excluding self)
const allVehicles = (await getCollection('services', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order)
  .filter(s => s.id !== entry.id);

// Show same category first, then others
const sameCategory = allVehicles.filter(s => s.data.category === entry.data.category);
const otherVehicles = sameCategory.length > 0 ? sameCategory.slice(0, 4) : allVehicles.slice(0, 4);
---

<BaseLayout title={`${entry.data.title} | Bush Bound`} description={entry.data.description}>

  <!-- Breadcrumb -->
  <section class="bg-charcoal pt-6 pb-0">
    <div class="container-narrow">
      <nav class="flex items-center gap-2 text-sm text-stone-dark">
        <a href="/fit-outs" class="hover:text-sand transition-colors">Vehicles</a>
        <span>/</span>
        <span class="text-stone-light">{entry.data.title}</span>
      </nav>
    </div>
  </section>

  <!-- Hero -->
  <section class="section-padding bg-charcoal text-stone-light">
    <div class="container-narrow">
      <div class="max-w-3xl">
        <span class="inline-flex items-center px-3 py-1 bg-white/10 text-sand text-xs font-semibold rounded-full mb-4">{entry.data.categoryLabel}</span>
        <h1 class="text-4xl sm:text-5xl font-extrabold mb-6">
          {entry.data.headline || entry.data.title}
        </h1>
        <p class="text-lg text-stone/90 max-w-2xl mb-8">
          {entry.data.description}
        </p>

        <div class="flex flex-wrap gap-6 text-sm">
          {entry.data.turnaround && (
            <div>
              <p class="text-stone-dark uppercase tracking-wider text-xs font-medium mb-1">Turnaround</p>
              <p class="text-stone-light font-semibold text-lg">{entry.data.turnaround}</p>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Build Photos -->
  {entry.data.heroImages && entry.data.heroImages.length > 0 && (
    <section class="bg-background pt-8 sm:pt-12">
      <div class="container-narrow">
        <div class="grid grid-cols-3 gap-3">
          {entry.data.heroImages.map((img: string, i: number) => (
            <div class="rounded-xl overflow-hidden bg-stone aspect-square">
              <img
                src={img}
                alt={`${entry.data.title} fit-out example ${i + 1}`}
                class="w-full h-full object-cover"
                loading={i === 0 ? 'eager' : 'lazy'}
              />
            </div>
          ))}
        </div>
        {entry.data.heroDisclaimer && (
          <p class="text-xs text-muted-foreground mt-3 text-center italic">{entry.data.heroDisclaimer}</p>
        )}
        {!entry.data.heroDisclaimer && entry.data.heroCaption && (
          <p class="text-sm text-muted-foreground mt-3 text-center italic">{entry.data.heroCaption}</p>
        )}
      </div>
    </section>
  )}

  <!-- Features -->
  {entry.data.features.length > 0 && (
    <section class="section-padding bg-stone">
      <div class="container-narrow">
        <h2 class="text-2xl font-bold text-charcoal mb-8" data-animate="fade-up">What's included</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4" data-animate="fade-up">
          {entry.data.features.map((feature) => (
            <div class="flex items-start gap-3 bg-white rounded-lg p-4 border border-stone-dark/10">
              <span class="text-primary font-bold mt-0.5 shrink-0">&#10003;</span>
              <span class="text-sm text-charcoal">{feature}</span>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Content body -->
  <section class="section-padding bg-background">
    <div class="container-narrow">
      <div class="prose prose-lg max-w-3xl
        [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:text-charcoal [&_h2]:mb-4 [&_h2]:mt-0
        [&_h3]:text-xl [&_h3]:font-bold [&_h3]:text-charcoal [&_h3]:mb-3
        [&_p]:text-muted-foreground [&_p]:leading-relaxed [&_p]:mb-4
        [&_ul]:space-y-2 [&_ul]:mb-4
        [&_li]:text-muted-foreground
        [&_strong]:text-charcoal
      ">
        <Content />
      </div>
    </div>
  </section>

  <!-- Other vehicles -->
  {otherVehicles.length > 0 && (
    <section class="section-padding bg-stone">
      <div class="container-narrow">
        <h2 class="text-2xl font-bold text-charcoal mb-8" data-animate="fade-up">Other vehicles we fit out</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6" data-animate="fade-up">
          {otherVehicles.map((model) => (
            <a href={`/fit-outs/${model.id}`} class="group bg-white rounded-xl p-6 border border-stone-dark/10 hover:border-primary/30 hover:shadow-sm transition-all">
              <span class="inline-flex items-center px-2.5 py-0.5 bg-primary/10 text-primary text-xs font-semibold rounded-full mb-2">{model.data.categoryLabel}</span>
              <h3 class="text-lg font-bold text-charcoal mb-1 group-hover:text-primary transition-colors">{model.data.title}</h3>
              <p class="text-sm text-muted-foreground line-clamp-2">{model.data.description}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="relative overflow-hidden">
    <div class="bg-gradient-to-br from-primary-dark via-primary to-primary-light py-16 sm:py-20">
      <div class="container-narrow text-center relative z-10">
        <div class="flex items-center justify-center gap-1.5 mb-6">
          {[1,2,3,4,5].map(() => (
            <svg class="w-5 h-5 text-sand" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>
        <h2 class="text-3xl sm:text-4xl font-bold text-primary-foreground mb-4">
          Get a quote for your {entry.data.title.replace(' Fit-Out', '').replace(' fit-out', '')}
        </h2>
        <p class="text-stone-light/80 text-lg mb-8 max-w-lg mx-auto">
          Tell us about your vehicle and we'll give you a call to talk through the design and build something perfect for you.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/quote" class="inline-flex items-center justify-center px-8 py-4 bg-sand text-charcoal font-bold text-base rounded-md hover:bg-sand-light transition-colors">
            Get a Free Quote
          </a>
          <a href="/quote?type=consultation" class="inline-flex items-center justify-center px-8 py-4 border-2 border-stone-light/30 text-stone-light font-semibold text-base rounded-md hover:border-sand hover:text-sand transition-colors">
            Book a Consultation
          </a>
        </div>
      </div>
      <div class="absolute top-0 left-0 w-64 h-64 bg-white/5 rounded-full -translate-x-1/2 -translate-y-1/2"></div>
      <div class="absolute bottom-0 right-0 w-48 h-48 bg-white/5 rounded-full translate-x-1/3 translate-y-1/3"></div>
    </div>
  </section>

</BaseLayout>
