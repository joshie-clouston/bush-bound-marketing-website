---
export const prerender = true;

import BaseLayout from '@/layouts/BaseLayout.astro';
import { faqs } from '@/data/faqs';

export function getStaticPaths() {
  return faqs.map((faq) => ({
    params: { slug: faq.slug },
    props: { faq },
  }));
}

const { faq } = Astro.props;
const relatedFaqs = faq.related
  .map((slug) => faqs.find((f) => f.slug === slug))
  .filter(Boolean);
---

<BaseLayout
  title={`${faq.question} | Bush Bound FAQ`}
  description={faq.answer}
>
  <section class="section-padding bg-background">
    <div class="container-narrow max-w-3xl">
      <a href="/faq" class="inline-flex items-center text-sm text-primary font-medium mb-6 hover:text-primary-light transition-colors">
        <svg class="w-4 h-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        All FAQs
      </a>

      <!-- Question -->
      <h1 class="text-3xl sm:text-4xl font-bold text-charcoal mb-10">
        {faq.question}
      </h1>

      <!-- Direct Answer -->
      <div class="mb-10">
        <h2 class="text-xs font-semibold text-sand-dark uppercase tracking-wider mb-3">Direct Answer</h2>
        <div class="bg-white rounded-xl border border-stone-dark/10 p-6 sm:p-8">
          <p class="text-lg text-charcoal leading-relaxed">{faq.answer}</p>
        </div>
      </div>

      <!-- Authority / Why -->
      <div class="mb-12">
        <h2 class="text-xs font-semibold text-sand-dark uppercase tracking-wider mb-3">Why?</h2>
        <div class="bg-white rounded-xl border border-stone-dark/10 p-6 sm:p-8">
          <p class="text-muted-foreground leading-relaxed">{faq.authority}</p>
        </div>
      </div>

      <!-- Related FAQs -->
      {relatedFaqs.length > 0 && (
        <div class="mb-12">
          <h2 class="text-xs font-semibold text-sand-dark uppercase tracking-wider mb-3">Related Questions</h2>
          <div class="space-y-2">
            {relatedFaqs.map((related) => (
              <a href={`/faq/${related!.slug}`} class="group flex items-center justify-between p-4 bg-white rounded-xl border border-stone-dark/10 hover:border-primary/30 hover:shadow-sm transition-all">
                <span class="font-medium text-charcoal group-hover:text-primary transition-colors text-sm">{related!.question}</span>
                <svg class="w-4 h-4 text-muted-foreground group-hover:text-primary shrink-0 ml-4 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="relative overflow-hidden">
    <div class="bg-gradient-to-br from-primary-dark via-primary to-primary-light py-16 sm:py-20">
      <div class="container-narrow text-center relative z-10">
        <div class="flex items-center justify-center gap-1.5 mb-6">
          {[1,2,3,4,5].map(() => (
            <svg class="w-5 h-5 text-sand" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>
        <h2 class="text-3xl sm:text-4xl font-bold text-primary-foreground mb-4">
          Ready to get started?
        </h2>
        <p class="text-stone-light/80 text-lg mb-8 max-w-lg mx-auto">
          Tell us about your vehicle and we'll give you a call to talk through the design and build something perfect for you.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/quote" class="inline-flex items-center justify-center px-8 py-4 bg-sand text-charcoal font-bold text-base rounded-md hover:bg-sand-light transition-colors">
            Get a Free Quote
          </a>
          <a href="/" class="inline-flex items-center justify-center px-8 py-4 border-2 border-stone-light/30 text-stone-light font-semibold text-base rounded-md hover:border-sand hover:text-sand transition-colors">
            Learn More
          </a>
        </div>
      </div>
      <div class="absolute top-0 left-0 w-64 h-64 bg-white/5 rounded-full -translate-x-1/2 -translate-y-1/2"></div>
      <div class="absolute bottom-0 right-0 w-48 h-48 bg-white/5 rounded-full translate-x-1/3 translate-y-1/3"></div>
    </div>
  </section>

</BaseLayout>
