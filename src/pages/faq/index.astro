---
export const prerender = true;

import BaseLayout from '@/layouts/BaseLayout.astro';
import { faqs } from '@/data/faqs';
---

<BaseLayout title="FAQ | Vehicle Fit-Out Questions Answered | Bush Bound" description="Common questions about custom vehicle fit-outs. Timelines, pricing, materials, warranty and more. Gold Coast, QLD.">

  <section class="section-padding bg-background">
    <div class="container-narrow max-w-3xl">
      <a href="/" class="inline-flex items-center text-sm text-primary font-medium mb-6 hover:text-primary-light transition-colors">
        <svg class="w-4 h-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        Back to home
      </a>

      <div class="text-center mb-12">
        <p class="text-sand-dark font-medium text-sm uppercase tracking-widest mb-3">FAQ</p>
        <h1 class="text-3xl sm:text-4xl font-bold text-charcoal mb-4">
          Vehicle fit-out questions answered
        </h1>
        <p class="text-muted-foreground text-lg max-w-2xl mx-auto">
          Everything you need to know about getting a custom fit-out with Bush Bound.
        </p>
      </div>

      <div class="space-y-3">
        {faqs.map((faq) => (
          <a href={`/faq/${faq.slug}`} class="group flex items-center justify-between p-5 bg-white rounded-xl border border-stone-dark/10 hover:border-primary/30 hover:shadow-sm transition-all">
            <span class="font-semibold text-charcoal group-hover:text-primary transition-colors">{faq.question}</span>
            <svg class="w-5 h-5 text-muted-foreground group-hover:text-primary shrink-0 ml-4 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="relative overflow-hidden">
    <div class="bg-gradient-to-br from-primary-dark via-primary to-primary-light py-16 sm:py-20">
      <div class="container-narrow text-center relative z-10">
        <h2 class="text-3xl sm:text-4xl font-bold text-primary-foreground mb-4">
          Still have questions?
        </h2>
        <p class="text-stone-light/80 text-lg mb-8 max-w-lg mx-auto">
          Submit a quote request and we'll call you within 48 hours to talk through everything.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/quote" class="inline-flex items-center justify-center px-8 py-4 bg-sand text-charcoal font-bold text-base rounded-md hover:bg-sand-light transition-colors">
            Get a Free Quote
          </a>
          <a href="/" class="inline-flex items-center justify-center px-8 py-4 border-2 border-stone-light/30 text-stone-light font-semibold text-base rounded-md hover:border-sand hover:text-sand transition-colors">
            Learn More
          </a>
        </div>
      </div>
      <div class="absolute top-0 left-0 w-64 h-64 bg-white/5 rounded-full -translate-x-1/2 -translate-y-1/2"></div>
      <div class="absolute bottom-0 right-0 w-48 h-48 bg-white/5 rounded-full translate-x-1/3 translate-y-1/3"></div>
    </div>
  </section>

</BaseLayout>
